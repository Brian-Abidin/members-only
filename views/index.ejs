<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head')%>
<body class="bg-purple-200 m-0 p-0">
  <div class="m-0 p-0 grid grid-rows-[1fr_auto] gap-0 bg-purple-500 h-screen">
    <% if (locals.user) {%>
      <div>
        <h1 class="text-green-400">WELCOME BACK <%= user.username %></h1>
        <a href="/message">new message!</a>
        <a href="/members-form">Become a member!</a>
        <a href="/log-out">LOG OUT</a>
      </div>
    <% } else { %>
      <div class="m-0 p-0 flex items-start justify-center bg-amber-200 h-screen">
        <div class=" flex-1 grid grid-rows-2 h-full w-full">
          <div class="flex flex-col items-center justify-center bg-green-500 h-full">
            <h1 class="text-5xl text-white">Members Only Club</h1>
            <h2 class="text-3xl text-white">Become a member today.</h2>
          </div>
          <div class="flex flex-col items-center justify-center gap-8 bg-green-500">
            <a class="flex justify-center items-center no-underline bg-green-700  text-white text-shadow-sm w-78 h-12 rounded-xl" href="/log-in">Log In</a>
            <a class="flex justify-center items-center no-underline bg-green-700 text-white text-shadow-sm w-78 h-12 rounded-xl" href="/sign-up">Create an Account</a>
          </div>
        </div>
        <div class="max-md:hidden flex-1 grid grid-rows-4 items-center overflow-hidden bg-green-400 h-full w-full gap-5">
          <%- include('./partials/carousel')%>
          <%- include('./partials/carousel-rev')%>
          <%- include('./partials/carousel')%>
          <%- include('./partials/carousel-rev')%>
        </div>
      </div>
      <div class="bg-green-950 h-14 flex items-center justify-center text-white">FOOTER</div>
    <%}%>
  </div>

</body>
</html>