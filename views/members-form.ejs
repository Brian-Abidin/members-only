<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head')%>
<body class="m-0 p-0 font-[arial]">
    <%- include('./partials/header')%>
    <div class="pt-10 flex items-start justify-center min-h-screen bg-[url('/images/blue-bg.svg')] bg-cover">
    <% if( member ) { %>
      <h2 class="m-0">Hey, you're already a member!</h2>
    <%} else { %>
      <form class="m-2 p-5 flex flex-col items-center text-slate-50 bg-slate-600/60 rounded-2xl gap-2" action="/members-form" method="POST">
        <h2>Enter the secret member code to join!</h2>
          <div class="m-0 p-2 flex flex-col items-start justify-start w-full h-fit gap-1 bg-slate-800 rounded-md border-2 border-slate-500">
            <label class="text-2xl" for="secret-code">Secret Code</label>
            <input class="h-5 w-50" id="secret-code" name="secret-code" type="password" autocomplete="off" required/>
          </div>
          <button class="mt-5 bg-slate-50 h-10 w-20 rounded-xl text-lg border-none self-end" type="submit">Enter</button>

      </form>
    <%} %>
  </div>
</body>
</html>