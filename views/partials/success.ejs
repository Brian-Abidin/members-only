<div class="w-full h-screen font-[arial]">
  <%- include('./header')%>
  <div class="w-full min-h-screen h-fit flex bg-[url('/images/blue-bg.svg')] bg-cover bg-no-repeat">
    <div class="flex flex-1 "></div>
    <div class="flex flex-3 justify-center ">
     <!-- Message container -->
      <div class="m-2 flex flex-col max-w-150 flex-1  gap-2">
      <% for(let i = messages.length-1; i >= 0; i-=1){ %>
        <% const date = new Date(messages[i].absolute_time) %>
        <% const time = (new Date() - date)/(1000 * 60 * 60 * 24) %>
        <%- include('./message', {i, time})%>
      <%}%>
      </div>
    </div>
    <div class="flex flex-1 "></div>
  </div>
</div>
