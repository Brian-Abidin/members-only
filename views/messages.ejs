<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head')%>
<body class="m-0 p-0 font-[arial]">
    <%- include('./partials/header')%>
    <div class="pt-10 flex items-start justify-center min-h-screen bg-[url('/images/blue-bg.svg')] bg-cover">
        <div class="w-fit p-5 grid grid-cols-2 bg-gray-200/60 rounded-2xl gap-5">
            <%- include('./partials/singleMessage')%>
            <div class="p-2 text-wrap border-r-2 border-slate-800">
                <h1 class="underline">Details</h1>
                <p><strong>Title:</strong> <%= foundMessage.title %></p>
                <p><strong>Author:</strong> <%= author %></p>
                <p class="max-w-50 text-wrap"><strong>Time Sent:</strong> <%= foundMessage.absolute_time %></p>
            </div>
            <div class="p-2 rounded-2xl">
                <h1 class="underline">Admin Tools</h1>
                <% if(admin) { %>
                    <button id="delete-btn" class="p-2 border-none bg-sky-700 hover:bg-sky-900 text-base rounded-xl cursor-grab text-slate-50">Delete Message</button>
                <%} else { %>
                    <div>Admin access only.</div>
                <%} %>
            </div>
        </div>
    </div>
    <dialog id="delete-modal" class="hidden fixed items-center justify-center top-0 right-0 w-screen h-screen bg-slate-800/60">
        <div class="p-3 flex flex-col w-fit bg-slate-50 border-2 border-slate-500 rounded-2xl">
            <p>Are you sure you want to delete this message?</p>
            <div class="flex items-center justify-between">
                <form action="/delete" method="POST">
                    <input class="hidden" type="text" name="message_id" value="<%= id %>" readonly>
                    <button>Yes</button>
                </form> 
                <button onclick="closeModal()">No</button>
            </div>
        </div>
    </dialog>
    <script src="/js/script.js" defer></script>
</body>
</html>