<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head')%>
<body class="m-0 p-0 font-[arial]">
    <%- include('./partials/header')%>
    <div class="pt-10 flex items-start justify-center min-h-screen bg-[url('/images/blue-bg.svg')] bg-cover">
        <%- include('./partials/singleMessage')%>
    </div>
    <dialog id="delete-modal" class="hidden fixed top-0 left-0 items-center justify-center w-screen h-screen bg-slate-800/50">
        <div class="p-3 flex flex-col bg-slate-50 border-2 border-slate-500 rounded-2xl">
            <p>Are you sure you want to delete this message?</p>
            <div class="flex items-center justify-between">
                <form action="/delete" method="POST">
                    <input class="hidden" type="text" name="message_id" value="<%= id %>" readonly>
                    <button>Yes</button>
                </form> 
                <button onclick="closeModal()">No</button>
            </div>
        </div>
    </dialog>
    <script src="/js/script.js" defer></script>
</body>
</html>