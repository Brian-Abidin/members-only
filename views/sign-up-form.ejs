<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head')%>
<body class="p-0 m-0">
  <div class="max-md:flex-col max-md:justify-items-center max-md:items-center flex w-full h-screen bg-sky-900 text-slate-50">
    <div class="flex w-full h-fit flex-col flex-1 gap-40 max-md:gap-0 max-md:flex-none">
      <header class="mt-5 p-0 flex items-center justify-center h-20">
        
        <a class="flex items-center h-fit text-slate-50 no-underline text-4xl font-bold gap-5" href="/">
          <img class="max-sm:h-12 max-sm:w-12 h-20 w-20" src="../icons/letter-m.png" alt="">
          <h1 class="max-sm:text-3xl text-5xl">Members Only</h1>
        </a>
      </header>
      <div class="max-md:hidden h-full flex flex-col items-center justify-start w-full">
        <div class="text-3xl "><h2>Create your account</h2></div>
        <div class=" text-lg">Few steps away from being a member!</div>
      </div>
    </div>
    <div class="flex-1 h-full w-full">
      <form class="h-full flex flex-col items-center justify-center gap-4" action="/sign-up" method="POST">
        <div class="p-1 w-fit flex flex-col items-start justify-items-center h-fit ">
          <label class="max-sm:text-sm" for="username">Username</label>
          <input class="max-sm:w-50 max-sm:h-10 max-sm:text-sm pl-2 w-75 h-15 placeholder:text-slate-400 text-lg bg-slate-800" id="username" name="username" placeholder="Username" type="text" autocomplete="off" required/>
        </div>
        <div class="p-1 w-fit flex flex-col items-start justify-items-center h-fit ">
          <label class="max-sm:text-sm" for="password">Password</label>
          <input class="max-sm:w-50 max-sm:h-10 max-sm:text-sm pl-2 w-75 h-15 text-lg placeholder:text-slate-400 bg-slate-800" id="password" name="password" placeholder="Password" type="password" required/>
        </div>
        <div class="p-1 w-fit flex flex-col items-start justify-items-center h-fit ">
          <label class="max-sm:text-sm" for="confirm-password">Confirm Password</label>
          <input class="max-sm:w-50 max-sm:h-10 max-sm:text-sm pl-2 w-75 h-15 text-lg placeholder:text-slate-400 bg-slate-800" id="confirm-password" name="confirm-password" placeholder="Confirm password" type="password" required>
        </div>
        <div class="p-1 w-fit flex flex-col items-start justify-items-center h-fit ">
          <label class="max-sm:text-sm" for="first-name">First Name</label>
          <input class="max-sm:w-50 max-sm:h-10 max-sm:text-sm pl-2 w-75 h-15 text-lg placeholder:text-slate-400 bg-slate-800" id="first-name" name="first-name" placeholder="First name" type="text" autocomplete="off" required/>
        </div>
        <div class="p-1 w-fit flex flex-col items-start justify-items-center h-fit ">
          <label class="max-sm:text-sm" for="last-name">Last Name</label>
          <input class="max-sm:w-50 max-sm:h-10 max-sm:text-sm pl-2 w-75 h-15 text-lg placeholder:text-slate-400 bg-slate-800" id="last-name" name="last-name" placeholder="Last name" type="text" autocomplete="off"required/>
        </div>
        <button class="max-sm:w-60 mt-5 w-80 h-15 border-none rounded-2xl text-lg text-slate-50 bg-sky-500 cursor-grab" type="submit">Sign Up</button>
      </form>
    </div>
  </div>
</body>
</html>