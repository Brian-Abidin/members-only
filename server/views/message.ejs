<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
  <h1>New Message</h1>
  <form action="/new-message" method="POST">
    <label for="title">Title</label>
    <input id="title" name="title" placeholder="title" type="text" autocomplete="off"/>
    <label for="password">Password</label>
    <input id="password" name="password" type="password" />
    <label for="first-name">First Name</label>
    <input id="first-name" name="first-name" placeholder="John" type="text" autocomplete="off"/>
        <label for="last-name">Last Name</label>
    <input id="last-name" name="last-name" placeholder="Smith" type="text" autocomplete="off"/>
    <button type="submit">Sign Up</button>
  </form>
</body>
</html>